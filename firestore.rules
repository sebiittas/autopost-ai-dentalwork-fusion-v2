rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }

    function userImmutableFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['rol', 'plan', 'stripeCustomerId']);
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.rol == 'user';
      allow update: if isOwner(uid) && userImmutableFieldsUnchanged();
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.usuarioEmail == request.auth.token.email;
      allow update, delete: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
